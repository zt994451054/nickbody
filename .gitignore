# 根目录白名单：只允许以下内容，其他全部自动忽略
/*

# 允许的根目录文件
!/.gitignore
!/.cursorrules
!/.windsurfrules
!/CLAUDE.md
!/AGENTS.md
!/README.md
!/SETUP.md
!/OSS.md
!/overview.png

# 允许的顶层目录
!/foundation/
!/standards/
!/engineering/
!/testing/
!/versions/

# 研发工程代码不纳入驱动面板（所有工程 clone 到 engineering/workspace/<name>/）
engineering/workspace/*
!engineering/workspace/.gitkeep

# 测试工程代码不纳入驱动面板
testing/*/workspace/*
!testing/*/workspace/.gitkeep

# 高保真交互原型工程不纳入驱动面板
versions/*/product/prototypes/workspace/*
!versions/*/product/prototypes/workspace/.gitkeep

# 原型设计工程构建产物与依赖（不入 git）
foundation/design/prototype/dist/
foundation/design/prototype/node_modules/
